# 复制为 .env 或直接在 shell 里 export（.env 已被 .gitignore 忽略）
SILICONFLOW_API_KEY=sk-在硅基流动控制台创建

# ---------- HTTP 接口（前端按需调用；鉴权同下）----------
# 情绪汇总：GET/POST /api/intraday
# 涨停池：GET /api/limit_up?date=YYYYMMDD（date 可选，默认上海当日）
# 跌停池：GET /api/limit_down?date=YYYYMMDD
# 请求头：Authorization: Bearer <secret>（任选其一环境变量）
INTRADAY_API_SECRET=随机长字符串
# CRON_SECRET=同上（兼容旧名，与 INTRADAY_API_SECRET 二选一即可）
# 跨次调用对比早盘与 14:30 需 Upstash Redis（与 Vercel KV 兼容的 REST）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# 强预警推送（至少配一个）
FEISHU_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
# 可选：冰点试错规则阈值（见 intraday_alerts.evaluate_ice_point_reversal）
# ALERT_TEMP_FLOOR=55
# ALERT_TEMP_DELTA_MIN=30
# ALERT_DT_RATIO_MAX=0.5
# ALERT_DT_DROP_MIN=3

# ---------- FastAPI 全能引擎（main.py：盘中实时 + 15:05 盘后 AI + 飞书写表）----------
# 与 market-web 复盘页使用同一套飞书情绪表（列名：日期、涨停数、跌停数、情绪温度、情绪结论、空间龙、空间龙连板）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_BITABLE_TABLE_ID_ZT=
# 启动示例：cd market-skills && uvicorn main:app --host 0.0.0.0 --port 8787
# 可选：盘中预警阈值（见 services/alert_engine.py）
# ALERT_DT_RATIO=0.45
# ALERT_DT_ABS=25
